# Copy this file to `wrangler.toml` (which is gitignored), then deploy.
# Do NOT put your Ravelry username/password here — they go in as encrypted SECRETS:
#   npx wrangler secret put RAVELRY_USER
#   npx wrangler secret put RAVELRY_PASS
# (or in the Cloudflare dashboard: Workers → your worker → Settings → Variables → "Encrypt")

name = "crochet-ravelry-proxy"
main = "worker.js"
compatibility_date = "2024-11-01"

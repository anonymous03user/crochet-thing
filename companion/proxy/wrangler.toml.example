# Copy this file to `wrangler.toml` (which is gitignored), then deploy.
# Do NOT put your Anthropic API key here — it goes in as an encrypted SECRET:
#   npx wrangler secret put ANTHROPIC_API_KEY
# (or in the Cloudflare dashboard: Workers → your worker → Settings → Variables → "Encrypt")
#
# Optional: set MODEL as a plain variable to override the default (claude-opus-4-8),
# e.g. MODEL = "claude-haiku-4-5" to trade some quality for lower cost.

name = "crochet-companion-ai"
main = "worker.js"
compatibility_date = "2024-11-01"

# [vars]
# MODEL = "claude-opus-4-8"

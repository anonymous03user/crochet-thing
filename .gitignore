.DS_Store

# Ravelry proxy — never commit real config or secrets
substitute/proxy/wrangler.toml
substitute/proxy/.dev.vars
substitute/proxy/*.dev.vars
substitute/proxy/.wrangler/
substitute/proxy/node_modules/

# Companion AI proxy — never commit real config or secrets
companion/proxy/wrangler.toml
companion/proxy/.dev.vars
companion/proxy/*.dev.vars
companion/proxy/.wrangler/
companion/proxy/node_modules/
